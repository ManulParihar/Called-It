# Copy this file to .env.local and fill in the values.

# --- TxLINE match data ---
# Use the devnet host while testing. Switch to the mainnet host for the live feed.
TXLINE_BASE_URL=https://txline-dev.txodds.com
# Set to "true" to run the worker off a recorded log instead of the live stream.
TXLINE_REPLAY=false
# Speed multiplier for replay mode (for example 10 plays a match at 10x).
TXLINE_REPLAY_SPEED=10

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key is server only. Never expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Question generation (Anthropic) ---
ANTHROPIC_API_KEY=
# Model used to pick and phrase the match questions.
QUESTION_MODEL=claude-sonnet-5

# --- Solana ---
SOLANA_CLUSTER=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
# Base58 secret key for the backend settlement authority. Server only.
SETTLEMENT_AUTHORITY_SECRET=
