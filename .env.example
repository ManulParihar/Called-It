# Copy this file to .env.local and fill in the values.

# --- TxLINE match data ---
# Use the devnet host while testing. Switch to the mainnet host for the live feed.
TXLINE_BASE_URL=https://txline-dev.txodds.com
# Set to "true" to run the worker off a recorded log instead of the live stream.
TXLINE_REPLAY=false
# Speed multiplier for replay mode (for example 10 plays a match at 10x).
TXLINE_REPLAY_SPEED=10
# Activated API token for the data feed. Needed to show upcoming fixtures live on
# the create screen and to pull past matches with npm run pull:replays. Without
# it the app falls back to the seeded fixtures and the sample replay.
TXLINE_API_TOKEN=

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key is server only. Never expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Question generation (Anthropic) ---
ANTHROPIC_API_KEY=
# Model used to pick and phrase the match questions.
QUESTION_MODEL=claude-sonnet-5

# --- Solana ---
SOLANA_CLUSTER=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
# Rpc url the browser wallets use. Defaults to devnet when left blank.
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
# The deployed pool program id. Until this and the settlement key below are set,
# the app runs the pot in mock mode with no on chain transactions.
NEXT_PUBLIC_POOL_PROGRAM_ID=
# Public key of the backend settlement authority. Passed into each pool so the
# program knows who is allowed to pay it out.
NEXT_PUBLIC_SETTLEMENT_PUBKEY=
# Base58 or JSON array secret key for the backend settlement authority. This is
# the private half of NEXT_PUBLIC_SETTLEMENT_PUBKEY. Server only.
SETTLEMENT_AUTHORITY_SECRET=

# --- Wallet sign in (Privy) ---
# Privy app id for the live embedded wallet. Leave blank for local testing, where
# a browser keypair is used instead.
NEXT_PUBLIC_PRIVY_APP_ID=

# --- Judge / demo deployment only ---
# The New tester / Play / End game testing tools are hidden on any production
# build by default. Set this to "1" on a hosted judge deployment so a room can
# be driven through a replay match by hand instead of needing a real live
# fixture at the exact time someone is testing. Leave blank on a real
# production deployment.
NEXT_PUBLIC_ENABLE_DEV_TOOLS=
